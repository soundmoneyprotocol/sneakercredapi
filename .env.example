# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:19000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sneakercred
DATABASE_SSL=false

# Cache
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-key-min-32-characters-long-please
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# External APIs
FIRECRAWL_API_KEY=fc-xxxxx
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CONTRACT_ADDRESS=0x...

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SHOPIFY INTEGRATION (Merchant Import)
# ============================================
# From /shop/shopify.app.toml - OAuth for merchant imports
SHOPIFY_API_KEY=b0cdef30a61d2693817f1568cd6cd98b
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_DEV_STORE=solarahsessentials.myshopify.com
SHOPIFY_API_SCOPES=read_products,read_inventory,read_orders
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_OAUTH_CALLBACK_URL=http://localhost:3000/api/shopify/callback
